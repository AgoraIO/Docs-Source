@startuml
!include agora_skin.iuml

skinparam sequence {
    ArrowThickness 1.5
    LifeLineBorderThickness 1.5
    BoxBorderThickness 0
    GroupBorderThickness 1
    GroupBorderColor #999999
    GroupBackgroundColor #F8F8F8
    NoteBackgroundColor #FFFDE7
    NoteBorderColor #E0C000
    NoteBorderThickness 1
}

participant "User" as user
participant "Conversational AI Engine" as ai_engine
participant "Custom LLM" as llm

user -> ai_engine: Voice input
activate ai_engine #E3F2FD

ai_engine -> ai_engine: Convert speech to text (ASR)
ai_engine -> llm: Send text request
activate llm #EDE7F6

group Custom LLM detects and outputs special first-packet response
    llm -> llm: Detects the need to output\na special first-packet response
    note left
        The special first-packet response
        transmits metadata only.
        The content is not converted to
        speech (TTS) or played back.
    end note
    llm --> ai_engine: Special first-packet response\n(object: chat.completion.custom_metadata)
    ai_engine -> ai_engine: Process custom_metadata
    note left
        Configure interruption mode,
        update TTS parameters, etc.
    end note
end

group Custom LLM outputs subsequent responses
    llm --> ai_engine: Subsequent response packets\n(object: chat.completion.chunk)
    llm --> ai_engine: Streaming response complete
    deactivate llm
    ai_engine -> ai_engine: Convert response content to speech (TTS)
    ai_engine --> user: Voice reply
    deactivate ai_engine
end

@enduml